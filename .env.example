# application environment: development | production (default: development locally, production on Heroku when DYNO is set)
# APP_ENV=development

# Local API port (Heroku sets PORT in production; default in code is 8001 for local)
# PORT=8001

# Local PostgreSQL (used when APP_ENV=development and USE_HEROKU_DB is not set)
# POSTGRES_HOST=localhost
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=password
# POSTGRES_DB=northenvolunteerdb
# POSTGRES_PORT=5432

# If you want every environment (including local) to use the same Heroku Postgres:
# 1) Set USE_HEROKU_DB=true
# 2) Set DATABASE_URL to the full URL (get it from: heroku config:get DATABASE_URL -a <app>).
#    On Heroku itself you usually rely on the platform’s DATABASE_URL and do not paste URL parts in code.
# 3) Never commit real passwords; rotate credentials if they were ever exposed.
# USE_HEROKU_DB=true
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
# Run ad-hoc SQL with the same .env the app uses: ./scripts/run_sql.sh add_duty_type_all.sql
# (raw `psql "$DATABASE_URL"` in a new shell often has no DATABASE_URL and falls back to a bogus local DB)

# CORS: add your Vercel app origin (comma-separated if multiple)
# CORS_ORIGINS=https://your-app.vercel.app

# Public API URL for OpenAPI "Try it out" (auto: local in development, or set on Heroku)
# PUBLIC_API_BASE_URL=

# SQL logging (every query to logs). Default: off. Set SQL_ECHO=1 to debug.
# SQL_ECHO=0
# Recycle async pool connections to RDS/Postgres (seconds). Default: 300.
# DB_POOL_RECYCLE=300
# 422 validation: write to error log table in DB (extra latency). Default: off.
# LOG_VALIDATION_ERRORS_TO_DB=0

# Optional: force asyncpg SSL for the primary DB
# DATABASE_SSL=true

# Census DB for /api/cnic-usage/batch (separate from DATABASE_URL / volunteer data).
# If unset, the app uses defaults in main.py (see CENSUS_DATABASE_URL).
# If you compare results to "FamilyLevelDetails" in your SQL client, the host and
# database name here must be the same as in that client, or the API and your
# manual check will disagree.
# CENSUS_HOST=
# CENSUS_PORT=5432
# CENSUS_USER=
# CENSUS_PASSWORD=
# CENSUS_DB=census_db_updated
# (If Azure shows a typo like cenus_db_updated, set that exact name.)
